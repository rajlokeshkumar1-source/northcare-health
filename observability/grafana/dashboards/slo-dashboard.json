{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "NorthCare Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "description": "Cross-service SLO dashboard — error budget remaining, burn rates, and availability",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "SLO Compliance — All Services",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "displayMode": "color-background" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green",  "value": 0.9 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "service" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "desc": false, "displayName": "service" }]
      },
      "targets": [
        {
          "expr": "label_replace(slo:error_budget_remaining:hospital_core, \"service\", \"hospital-core\", \"\", \"\")",
          "legendFormat": "hospital-core",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "label_replace(slo:error_budget_remaining:billing, \"service\", \"billing\", \"\", \"\")",
          "legendFormat": "billing",
          "refId": "B",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Budget Remaining — Hospital Core",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 0.25 },
              { "color": "green",  "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "slo:error_budget_remaining:hospital_core",
          "legendFormat": "Error Budget",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Budget Remaining — Billing",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 0.25 },
              { "color": "green",  "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "slo:error_budget_remaining:billing",
          "legendFormat": "Error Budget",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Budget Remaining — Telehealth",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 0.25 },
              { "color": "green",  "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "slo:error_budget_remaining:telehealth",
          "legendFormat": "Error Budget",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Budget Remaining — Insurance",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 0.25 },
              { "color": "green",  "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "slo:error_budget_remaining:insurance",
          "legendFormat": "Error Budget",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Burn Rate (1h window) — All Services",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red",    "value": 14.4 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(1 - slo:http_availability:ratio_rate1h) / (1 - 0.995)",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Availability % — All Services (24h)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.98,
          "max": 1.001,
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "slo:http_availability:ratio_rate24h",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["northcare", "slo", "error-budget"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NorthCare — SLO & Error Budget Dashboard",
  "uid": "northcare-slo-overview",
  "version": 1
}
