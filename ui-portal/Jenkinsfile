pipeline {
    agent any
    environment {
        SERVICE_NAME = 'ui-portal'
        ECR_REGISTRY = credentials('ecr-registry')
        AWS_REGION = 'us-east-1'
        GITOPS_REPO = 'northcare-health/gitops-argocd'
        IMAGE_TAG = "${BUILD_NUMBER}-${GIT_COMMIT.take(7)}"
    }
    stages {
        stage('Install') { steps { sh 'npm ci' } }
        stage('Build') { steps { sh 'npm run build' } }
        stage('Docker Build') { steps { sh 'docker build -t $ECR_REGISTRY/$SERVICE_NAME:$IMAGE_TAG .' } }
        stage('Security Scan') { steps { sh 'docker run --rm aquasec/trivy image $ECR_REGISTRY/$SERVICE_NAME:$IMAGE_TAG --severity HIGH,CRITICAL --exit-code 0' } }
        stage('Push to ECR') {
            steps {
                sh '''
                    aws ecr get-login-password --region $AWS_REGION | docker login --username AWS --password-stdin $(echo $ECR_REGISTRY | cut -d/ -f1)
                    docker push $ECR_REGISTRY/$SERVICE_NAME:$IMAGE_TAG
                '''
            }
        }
        stage('Update GitOps') {
            when { branch 'main' }
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-creds', usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
                    sh '''
                        git clone https://$GH_USER:$GH_TOKEN@github.com/$GITOPS_REPO.git gitops-tmp
                        cd gitops-tmp
                        sed -i "s/tag: .*/tag: \\"$IMAGE_TAG\\"/" ui-portal/dev/values.yaml
                        git config user.email "jenkins@northcare-health.local"
                        git config user.name "Jenkins CI"
                        git add . && git commit -m "deploy(ui-portal): $IMAGE_TAG [skip ci]"
                        git push
                        cd .. && rm -rf gitops-tmp
                    '''
                }
            }
        }
    }
    post {
        success { echo "✅ ui-portal:${IMAGE_TAG} deployed" }
        failure { echo "❌ UI Pipeline failed" }
    }
}
